# ============================================================
# .env.example — 複製為 .env 並填入真實值，勿 commit .env
# ============================================================

# ── TDX 交通資料平台 ──────────────────────────────────────────
# 申請網址：https://tdx.transportdata.tw/register
TDX_CLIENT_ID='s11259024-dd9b7831-fa60-4e72'
TDX_CLIENT_SECRET='f092e301-760b-4585-b21a-fd4e45cc526c'

# ── 中央氣象署 Open Data ──────────────────────────────────────
# 申請網址：https://opendata.cwa.gov.tw/user/authkey
# 免費，申請後立即可用
CWB_API_KEY=CWA-C3D66018-AC17-4018-81E7-AA9B7A21F733

# ── 系統設定 ──────────────────────────────────────────────────
# SQLite 資料庫路徑
DB_PATH=taiwan_osm.db

# 自動同步間隔（秒）。設 0 停用自動同步。
# 建議：300（5分鐘）= TDX 車速更新頻率
AUTO_SYNC_INTERVAL=300
